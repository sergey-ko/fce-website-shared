---
interface Props {
  title?: string;
  lines: string[];
}

const { title = 'terminal', lines } = Astro.props;
---

<div class="rounded-xl border border-[var(--border)] overflow-hidden bg-[var(--bg-tertiary)]">
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-3 bg-[var(--bg-secondary)] border-b border-[var(--border)]">
    <div class="w-3 h-3 rounded-full bg-[#EF4444]"></div>
    <div class="w-3 h-3 rounded-full bg-[#F59E0B]"></div>
    <div class="w-3 h-3 rounded-full bg-[#22C55E]"></div>
    <span class="text-xs text-[var(--text-muted)] ml-2 font-mono">{title}</span>
  </div>
  <!-- Content -->
  <div class="p-4 font-mono text-sm leading-relaxed">
    {lines.map(line => (
      <div class="text-[var(--text-secondary)]" set:html={line} />
    ))}
  </div>
</div>
