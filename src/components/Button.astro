---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-3 text-lg',
};

const variants = {
  primary: 'bg-[var(--accent-primary)] text-[var(--accent-btn-text)] hover:opacity-90',
  secondary: 'border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)]',
};
---

<a
  href={href}
  class={`inline-block rounded-lg font-medium transition-all ${sizes[size]} ${variants[variant]} ${className}`}
>
  <slot />
</a>
