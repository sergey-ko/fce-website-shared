---
interface Tier {
  name: string;
  price: string;
  description: string;
  features: string[];
  cta: { text: string; href: string };
  highlighted?: boolean;
}

interface Props {
  headline?: string;
  subheadline?: string;
  tiers: Tier[];
}

const { headline = 'Pricing', subheadline, tiers } = Astro.props;
---

<section id="pricing" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center">{headline}</h2>
    {subheadline && (
      <p class="text-[var(--text-secondary)] text-center mt-4 max-w-2xl mx-auto">{subheadline}</p>
    )}
    <div class="grid md:grid-cols-3 gap-6 mt-12">
      {tiers.map(tier => (
        <div class={`rounded-xl p-6 md:p-8 border ${tier.highlighted ? 'border-[var(--accent-primary)] bg-[var(--bg-secondary)]' : 'border-[var(--border)] bg-[var(--bg-secondary)]'}`}>
          <h3 class="text-lg font-semibold">{tier.name}</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--accent-primary)]">{tier.price}</p>
          <p class="text-sm text-[var(--text-secondary)] mt-2">{tier.description}</p>
          <ul class="mt-6 space-y-3">
            {tier.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--accent-primary)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={tier.cta.href}
            class={`block text-center mt-8 px-6 py-3 rounded-lg font-medium transition-opacity hover:opacity-90 ${tier.highlighted ? 'bg-[var(--accent-primary)] text-[var(--accent-btn-text)]' : 'border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)]'}`}
          >
            {tier.cta.text}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
